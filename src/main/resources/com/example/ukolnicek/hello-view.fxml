<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="500.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ukolnicek.HelloController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <Label text="Správce školních úkolů">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <VBox spacing="8.0" style="-fx-background-color: #f4f4f4; -fx-padding: 10; -fx-background-radius: 5;">
        <TextField fx:id="taskInput" promptText="Zadej úkol..." />

        <HBox alignment="CENTER" spacing="15.0">
            <Label text="Předmět:" />
            <RadioButton text="MAT">
                <toggleGroup>
                    <ToggleGroup fx:id="subjectGroup"/>
                </toggleGroup>
            </RadioButton>
            <RadioButton text="AJ" toggleGroup="$subjectGroup"/>
            <RadioButton text="PRG" toggleGroup="$subjectGroup"/>
        </HBox>

        <HBox alignment="CENTER">
            <children>
                <CheckBox fx:id="splnenoCheck" text="Splněno"/>
            </children>
        </HBox>

        <Button maxWidth="1.7976931348623157E308" onAction="#addUkol" text="Přidat úkol"/>
    </VBox>

    <ListView fx:id="taskListView" VBox.vgrow="ALWAYS"/>

    <HBox alignment="CENTER" spacing="10.0">
        <Button onAction="#removeUkol" prefWidth="100.0" text="Smazat"/>
        <Button prefWidth="100.0" text="Načíst"/>
        <Button onAction="#ulozitZmeny" prefWidth="100.0" text="Uložit změny"/>
        <Button prefWidth="100.0" text="Detail"/>
    </HBox>

</VBox>